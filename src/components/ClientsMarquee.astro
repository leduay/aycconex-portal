---
import type { Lang } from '../i18n/utils';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const clients = [
  { name: 'MEHECO', logo: '/images/empresa-meheco.png' },
  { name: 'Beesun', logo: '/images/empresa-beesun.png' },
  { name: 'UNICO COMPANY', logo: '/images/empresa-unico-company.png' },
  { name: 'IDV', logo: '/images/empresa-idv.png' },
];
---

<section style="padding:4rem 0;background:#fff;overflow:hidden;border-top:1px solid #e5e7eb;border-bottom:1px solid #e5e7eb;position:relative;" class="reveal-on-scroll">
  <div style="position:absolute;top:0;left:0;width:6rem;height:100%;z-index:10;pointer-events:none;background:linear-gradient(to right,#fff,transparent);"></div>
  <div style="position:absolute;top:0;right:0;width:6rem;height:100%;z-index:10;pointer-events:none;background:linear-gradient(to left,#fff,transparent);"></div>

  <div class="container" style="text-align:center;margin-bottom:2rem;">
    <h3 style="color:#9ca3af;font-weight:700;letter-spacing:0.1em;font-size:0.875rem;text-transform:uppercase;">
      {t(lang, 'clients.title')}
    </h3>
  </div>

  <div style="overflow:hidden;width:100%;">
    <div style="display:flex;align-items:center;gap:5rem;width:max-content;animation:clients-slide 20s linear infinite;">
      {clients.map((c) => (
        <img src={c.logo} alt={c.name} width="250" height="100" style="height:100px;width:250px;object-fit:contain;flex-shrink:0;" />
      ))}
      {clients.map((c) => (
        <img src={c.logo} alt={c.name} width="250" height="100" style="height:100px;width:250px;object-fit:contain;flex-shrink:0;" aria-hidden="true" />
      ))}
    </div>
  </div>
</section>

<style>
  @media (max-width: 640px) {
    section {
      padding: 3rem 0 !important;
    }

    section > div:first-child,
    section > div:nth-child(2) {
      width: 3rem !important;
    }

    img {
      height: 80px !important;
      width: 200px !important;
    }

    div[style*="gap:5rem"] {
      gap: 3rem !important;
      animation-duration: 15s !important;
    }
  }
</style>
