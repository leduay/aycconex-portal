---
import type { Lang } from '../i18n/utils';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const clients = ['MEHECO', 'GREENUNION', 'TIANJIN HUAXUAN', 'UNICO COMPANY LTD', 'IDV'];
---

<section class="marquee-section reveal-on-scroll">
  <div class="marquee-fade-left"></div>
  <div class="marquee-fade-right"></div>

  <div class="container marquee-header">
    <h3 class="marquee-title">{t(lang, 'clients.title')}</h3>
  </div>

  <div class="animate-marquee">
    {[0, 1].map(() => (
      <div class="marquee-track">
        {clients.map((client) => (
          <div class="marquee-item">{client}</div>
        ))}
      </div>
    ))}
  </div>
</section>

<style>
  .marquee-section {
    padding: 4rem 0;
    background: var(--color-white);
    overflow: hidden;
    border-top: 1px solid var(--color-gray-200);
    border-bottom: 1px solid var(--color-gray-200);
    position: relative;
  }

  .marquee-fade-left,
  .marquee-fade-right {
    position: absolute;
    top: 0;
    width: 8rem;
    height: 100%;
    z-index: 10;
    pointer-events: none;
  }

  .marquee-fade-left {
    left: 0;
    background: linear-gradient(to right, var(--color-white), transparent);
  }

  .marquee-fade-right {
    right: 0;
    background: linear-gradient(to left, var(--color-white), transparent);
  }

  .marquee-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .marquee-title {
    color: var(--color-gray-400);
    font-weight: 700;
    letter-spacing: 0.1em;
    font-size: 0.875rem;
    text-transform: uppercase;
  }

  .marquee-track {
    display: flex;
    align-items: center;
    justify-content: space-around;
    width: 50%;
    padding: 0 3rem;
    gap: 4rem;
    filter: grayscale(1);
    opacity: 0.6;
    transition: all 0.3s ease;
  }

  .marquee-track:hover {
    filter: grayscale(0);
    opacity: 1;
  }

  .marquee-item {
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--color-gray-500);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .marquee-item:nth-child(1) {
    font-size: 1.875rem;
  }

  .marquee-item:nth-child(5) {
    font-size: 2.25rem;
  }
</style>
