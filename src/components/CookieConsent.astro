---
import type { Lang } from '../i18n/utils';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<div id="cookie-consent" class="cookie-bar" aria-hidden="true" role="alert">
  <div class="container cookie-inner">
    <p class="cookie-text">
      {t(lang, 'cookie.message')}
      <button type="button" class="cookie-link" data-privacy-trigger>{t(lang, 'contact.privacyLink')}</button>.
    </p>
    <div class="cookie-actions">
      <button id="cookie-reject" class="cookie-btn cookie-btn-reject">
        {t(lang, 'cookie.reject')}
      </button>
      <button id="cookie-accept" class="cookie-btn cookie-btn-accept">
        {t(lang, 'cookie.accept')}
      </button>
    </div>
  </div>
</div>

<style>
  .cookie-bar {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    z-index: 150;
    background: var(--color-gray-900);
    color: var(--color-gray-400);
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.2);
    border-top: 1px solid var(--color-gray-800);
    animation: slideUpBar 0.4s ease-out;
  }

  .cookie-bar.visible {
    display: block;
  }

  @keyframes slideUpBar {
    from { transform: translateY(100%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .cookie-inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    padding-top: 1.25rem;
    padding-bottom: 1.25rem;
  }

  @media (min-width: 768px) {
    .cookie-inner {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .cookie-text {
    font-size: 0.875rem;
    line-height: 1.5;
    flex: 1;
  }

  .cookie-link {
    color: var(--color-accent);
    font-weight: 600;
    text-decoration: underline;
    cursor: pointer;
    background: none;
    border: none;
    font-size: inherit;
    font-family: inherit;
    padding: 0;
  }

  .cookie-link:hover {
    color: var(--color-white);
  }

  .cookie-actions {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .cookie-btn {
    padding: 0.5rem 1.5rem;
    border-radius: 0.375rem;
    font-weight: 700;
    font-size: 0.8125rem;
    transition: all 0.2s ease;
    cursor: pointer;
    border: none;
    font-family: var(--font-family);
  }

  .cookie-btn-reject {
    background: var(--color-gray-800);
    color: var(--color-gray-400);
    border: 1px solid var(--color-gray-700);
  }

  .cookie-btn-reject:hover {
    background: var(--color-gray-700);
    color: var(--color-white);
  }

  .cookie-btn-accept {
    background: var(--color-primary);
    color: var(--color-white);
  }

  .cookie-btn-accept:hover {
    background: #003d57;
  }
</style>

<script>
  function initCookieConsent() {
    const bar = document.getElementById('cookie-consent');
    const acceptBtn = document.getElementById('cookie-accept');
    const rejectBtn = document.getElementById('cookie-reject');
    if (!bar || !acceptBtn || !rejectBtn) return;

    // Check if user already responded
    const consent = localStorage.getItem('aycconex-cookie-consent');
    if (!consent) {
      // Show after slight delay for better UX
      setTimeout(() => {
        bar.classList.add('visible');
        bar.setAttribute('aria-hidden', 'false');
      }, 1500);
    }

    acceptBtn.addEventListener('click', () => {
      localStorage.setItem('aycconex-cookie-consent', 'accepted');
      bar.classList.remove('visible');
      bar.setAttribute('aria-hidden', 'true');
    });

    rejectBtn.addEventListener('click', () => {
      localStorage.setItem('aycconex-cookie-consent', 'rejected');
      bar.classList.remove('visible');
      bar.setAttribute('aria-hidden', 'true');
    });
  }

  initCookieConsent();
  document.addEventListener('astro:page-load', initCookieConsent);
</script>
