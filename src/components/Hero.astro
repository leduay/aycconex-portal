---
import type { Lang } from '../i18n/utils';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<header class="hero" id="hero">
  <div class="hero-bg">
    <img
      src="https://images.unsplash.com/photo-1578575437130-527eed3abbec?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80"
      alt="Puerto comercial"
      class="hero-bg-img animate-slow-zoom"
      loading="eager"
    />
  </div>
  <div class="hero-overlay"></div>

  <div class="container hero-content reveal-on-scroll">
    <div class="hero-text">
      <div class="hero-badge animate-fade-in-down">
        {t(lang, 'hero.badge')}
      </div>
      <h1 class="hero-title">
        {t(lang, 'hero.title1')} <br />
        <span class="hero-title-gradient">{t(lang, 'hero.title2')}</span>
      </h1>
      <p class="hero-subtitle">
        {t(lang, 'hero.subtitle')}
      </p>
      <div class="hero-actions">
        <a href="#servicios-grid" class="hero-cta">
          {t(lang, 'hero.cta')}
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    background: var(--color-gray-900);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.5;
  }

  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(to right, rgba(0, 85, 121, 0.8), transparent);
    mix-blend-mode: multiply;
  }

  .hero-content {
    position: relative;
    z-index: 2;
  }

  .hero-text {
    max-width: 48rem;
  }

  .hero-badge {
    display: inline-block;
    background: var(--color-primary);
    color: var(--color-white);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 0.375rem 1rem;
    border-radius: 0.25rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 4px 15px rgba(0, 85, 121, 0.4);
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    color: var(--color-white);
    line-height: 1.1;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .hero-title-gradient {
    background: linear-gradient(to right, var(--color-white), #9ca3af);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.5rem);
    color: #d1d5db;
    margin-bottom: 2.5rem;
    max-width: 40rem;
    line-height: 1.6;
    font-weight: 300;
  }

  .hero-cta {
    display: inline-block;
    background: var(--color-accent);
    color: var(--color-white);
    font-weight: 700;
    font-size: 1.125rem;
    padding: 1rem 2rem;
    border-radius: 0.25rem;
    box-shadow: 0 0 20px rgba(239, 73, 76, 0.4);
    transition: all 0.3s ease;
    text-align: center;
  }

  .hero-cta:hover {
    background: #dc2626;
    transform: translateY(-2px);
    box-shadow: 0 0 30px rgba(239, 73, 76, 0.5);
  }

  @media (max-width: 640px) {
    .hero {
      min-height: 600px;
    }
  }
</style>
