---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import PrivacyModal from '../components/PrivacyModal.astro';
import CookieConsent from '../components/CookieConsent.astro';
import type { Lang } from '../i18n/utils';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  isServicePage?: boolean;
}

const { lang, title, description, isServicePage = false } = Astro.props;
const pageTitle = title || t(lang, 'meta.title');
const pageDesc = description || t(lang, 'meta.description');

// SEO: Base URL and canonical
const siteUrl = 'https://www.aycconex.com';
const currentPath = Astro.url.pathname;
const canonicalUrl = `${siteUrl}${currentPath}`;

// SEO: hreflang alternate URLs
function getAlternatePath(targetLang: Lang): string {
  // Home pages
  if (currentPath === '/' || currentPath === '/en/' || currentPath === '/zh/') {
    if (targetLang === 'es') return '/';
    return `/${targetLang}/`;
  }
  // Service pages
  const esMatch = currentPath.match(/^\/servicios\/(.+?)(?:\/)?$/);
  const enMatch = currentPath.match(/^\/en\/services\/(.+?)(?:\/)?$/);
  const zhMatch = currentPath.match(/^\/zh\/services\/(.+?)(?:\/)?$/);
  const serviceId = esMatch?.[1] || enMatch?.[1] || zhMatch?.[1];
  if (serviceId) {
    if (targetLang === 'es') return `/servicios/${serviceId}`;
    if (targetLang === 'en') return `/en/services/${serviceId}`;
    if (targetLang === 'zh') return `/zh/services/${serviceId}`;
  }
  if (targetLang === 'es') return '/';
  return `/${targetLang}/`;
}

// SEO: JSON-LD Structured Data
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  'name': 'AYCCONEX',
  'alternateName': 'AYCCONEX',
  'url': siteUrl,
  'logo': `${siteUrl}/aycconex-color.png`,
  'description': t(lang, 'meta.description'),
  'foundingDate': '2014',
  'contactPoint': {
    '@type': 'ContactPoint',
    'email': 'comercial@aycconex.com',
    'contactType': 'customer service',
    'availableLanguage': ['Spanish', 'English', 'Chinese'],
  },
  'address': [
    {
      '@type': 'PostalAddress',
      'addressLocality': 'Montevideo',
      'addressCountry': 'UY',
    },
    {
      '@type': 'PostalAddress',
      'addressLocality': 'Shenzhen',
      'addressCountry': 'CN',
    },
  ],
  'sameAs': [],
  'areaServed': [
    { '@type': 'Country', 'name': 'Uruguay' },
    { '@type': 'Country', 'name': 'China' },
  ],
  'knowsLanguage': ['es', 'en', 'zh'],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  'name': 'AYCCONEX',
  'url': siteUrl,
  'inLanguage': lang,
  'description': pageDesc,
  'publisher': {
    '@type': 'Organization',
    'name': 'AYCCONEX',
  },
};

// OG image absolute URL
const ogImageUrl = `${siteUrl}/aycconex-color.png`;
---

<!doctype html>
<html lang={lang} dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDesc} />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO: Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- SEO: hreflang alternates for multilingual -->
    <link rel="alternate" hreflang="es" href={`${siteUrl}${getAlternatePath('es')}`} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}${getAlternatePath('en')}`} />
    <link rel="alternate" hreflang="zh" href={`${siteUrl}${getAlternatePath('zh')}`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${getAlternatePath('es')}`} />

    <!-- SEO: Additional meta tags -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="author" content="AYCCONEX" />
    <meta name="theme-color" content="#005579" />
    <meta name="keywords" content={
      lang === 'es' ? 'comercio internacional, China Uruguay, importación, exportación, representación comercial, turismo comercial, cadena de suministros, comercio exterior, AYCCONEX' :
      lang === 'en' ? 'international trade, China Uruguay, import, export, commercial representation, business tourism, supply chain, foreign trade, AYCCONEX' :
      '国际贸易, 中国乌拉圭, 进口, 出口, 商业代理, 商务旅游, 供应链, 外贸, AYCCONEX'
    } />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/aycconex-favicon.png" />
    <link rel="apple-touch-icon" href="/aycconex-favicon.png" />

    <!-- Google Fonts: Inter (preload for performance) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- SEO: Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="800" />
    <meta property="og:image:height" content="200" />
    <meta property="og:image:alt" content="AYCCONEX - Comercio Internacional China-Uruguay" />
    <meta property="og:site_name" content="AYCCONEX" />
    <meta property="og:locale" content={
      lang === 'es' ? 'es_UY' : lang === 'en' ? 'en_US' : 'zh_CN'
    } />
    <meta property="og:locale:alternate" content="es_UY" />
    <meta property="og:locale:alternate" content="en_US" />
    <meta property="og:locale:alternate" content="zh_CN" />

    <!-- SEO: Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="AYCCONEX" />

    <!-- SEO: JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <title>{pageTitle}</title>
    <ClientRouter />
  </head>
  <body>
    <Navbar lang={lang} isServicePage={isServicePage} />
    <slot />
    <Footer lang={lang} />
    <WhatsAppButton lang={lang} />
    <PrivacyModal lang={lang} />
    <CookieConsent lang={lang} />

    <!-- Reveal on scroll script -->
    <script>
      function initReveal() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('animate-in');
              }
            });
          },
          { threshold: 0.1 }
        );
        document.querySelectorAll('.reveal-on-scroll').forEach((el) => observer.observe(el));
      }

      // Run on initial load and after view transitions
      initReveal();
      document.addEventListener('astro:page-load', initReveal);
    </script>
  </body>
</html>
